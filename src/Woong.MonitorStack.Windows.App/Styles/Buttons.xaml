<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="DashboardButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PrimaryButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DashboardButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PrimaryActionBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryActionBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryActionTextBrush}" />
    </Style>

    <Style x:Key="DangerButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DashboardButtonStyle}">
        <Setter Property="BorderBrush" Value="{StaticResource DangerActionBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DangerActionBrush}" />
    </Style>

    <Style x:Key="SecondaryButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DashboardButtonStyle}" />

    <Style x:Key="PeriodButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DashboardButtonStyle}" />

    <Style x:Key="SelectedPeriodButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource PeriodButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PrimaryActionBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryActionBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryActionTextBrush}" />
    </Style>

    <Style x:Key="CompactActionButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryActionBrush}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PagerIconButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource CompactActionButtonStyle}">
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="18" />
    </Style>
</ResourceDictionary>

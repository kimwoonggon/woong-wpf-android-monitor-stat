<UserControl x:Class="Woong.MonitorStack.Windows.App.Controls.MetricCard"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Margin="0,0,8,12"
            Padding="18"
            CornerRadius="8"
            Background="White"
            BorderBrush="#DCE1E8"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="{Binding Label, ElementName=Root}"
                       Foreground="#162033"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding Value, ElementName=Root}"
                       Foreground="#162033"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,8,0,0" />
            <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                       Foreground="#5A6472"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0" />
        </StackPanel>
    </Border>
</UserControl>

<UserControl x:Class="Woong.MonitorStack.Windows.App.Controls.SectionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Cards.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Typography.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Margin="{Binding CardMargin, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
            Style="{StaticResource DashboardCardBorderStyle}">
        <DockPanel>
            <Grid DockPanel.Dock="Top"
                  Margin="0,0,0,12"
                  Visibility="{Binding HasHeader, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                           Style="{StaticResource SectionTitleTextStyle}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        AutomationProperties.AutomationId="SectionCardActionButton"
                        Content="{Binding ActionText, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                        Command="{Binding ActionCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                        MinHeight="28"
                        MinWidth="72"
                        Padding="10,0"
                        FontSize="12"
                        Visibility="{Binding HasAction, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
            <ContentPresenter Content="{Binding CardContent, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
        </DockPanel>
    </Border>
</UserControl>

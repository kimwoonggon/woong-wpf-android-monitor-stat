<UserControl x:Class="Woong.MonitorStack.Windows.App.Controls.EmptyState"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Typography.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <TextBlock AutomationProperties.AutomationId="{Binding TextAutomationId, ElementName=Root}"
               Text="{Binding Text, ElementName=Root}"
               Style="{StaticResource EmptyStateTextStyle}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
</UserControl>

<UserControl x:Class="Woong.MonitorStack.Windows.App.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="{Binding Text, RelativeSource={RelativeSource Self}}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Badges.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource StatusBadgeBorderStyle}"
            Background="{Binding BadgeBackground, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
            BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
        <TextBlock Text="{Binding Text, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                   Foreground="{Binding TextBrush, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                   Style="{StaticResource StatusBadgeTextStyle}" />
    </Border>
</UserControl>

<UserControl x:Class="Woong.MonitorStack.Windows.App.Views.DetailsTabsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Woong.MonitorStack.Windows.App.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dashboard="clr-namespace:Woong.MonitorStack.Windows.Presentation.Dashboard;assembly=Woong.MonitorStack.Windows.Presentation"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:Woong.MonitorStack.Windows.App.Views"
             mc:Ignorable="d"
             AutomationProperties.AutomationId="DetailsTabsPanel"
             d:DataContext="{d:DesignInstance dashboard:DashboardViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Colors.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Cards.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Buttons.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/DataGrid.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Tabs.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Typography.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:ProcessIconImageSourceConverter x:Key="ProcessIconImageSourceConverter" />
            <converters:ProcessIconVisibilityConverter x:Key="ProcessIconVisibilityConverter" />
            <converters:ProcessIconVisibilityConverter x:Key="ProcessIconFallbackVisibilityConverter"
                                                       Invert="True" />
            <converters:AppNameFallbackGlyphConverter x:Key="AppNameFallbackGlyphConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource DashboardCardBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TabControl AutomationProperties.AutomationId="DashboardTabs"
                        AutomationProperties.Name="Dashboard details tabs"
                        Style="{StaticResource DashboardTabControlStyle}"
                        ItemContainerStyle="{StaticResource DashboardTabItemStyle}"
                        SelectedValue="{Binding SelectedDetailsTab, Mode=TwoWay}"
                        SelectedValuePath="Tag">
                <TabItem Tag="{x:Static dashboard:DetailsTab.AppSessions}"
                         AutomationProperties.AutomationId="AppSessionsTab"
                         AutomationProperties.Name="App Sessions">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock AutomationProperties.AutomationId="AppSessionsTabIcon"
                                       Text="▦"
                                       Style="{StaticResource TabHeaderIconTextStyle}" />
                            <TextBlock Text="App Sessions" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid AutomationProperties.AutomationId="AppSessionsList">
                        <DataGrid AutomationProperties.AutomationId="RecentAppSessionsList"
                                  AutomationProperties.Name="Recent app sessions"
                                  Style="{StaticResource SessionDataGridStyle}"
                                  ItemsSource="{Binding VisibleAppSessionRows}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="App"
                                                        MinWidth="160"
                                                        Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border AutomationProperties.AutomationId="AppSessionAppIcon"
                                                        Style="{StaticResource AppSessionIconCircleStyle}">
                                                    <Grid>
                                                        <Image AutomationProperties.AutomationId="AppSessionProcessIconImage"
                                                               Source="{Binding ProcessPath, Converter={StaticResource ProcessIconImageSourceConverter}}"
                                                               Visibility="{Binding ProcessPath, Converter={StaticResource ProcessIconVisibilityConverter}}"
                                                               Width="18"
                                                               Height="18"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                        <TextBlock AutomationProperties.AutomationId="AppSessionAppIconText"
                                                                   Text="{Binding AppName, Converter={StaticResource AppNameFallbackGlyphConverter}}"
                                                                   Visibility="{Binding ProcessPath, Converter={StaticResource ProcessIconFallbackVisibilityConverter}}"
                                                                   Style="{StaticResource AppSessionIconTextStyle}" />
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding AppName}"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Process"
                                                    Binding="{Binding ProcessName}"
                                                    MinWidth="180"
                                                    Width="180" />
                                <DataGridTextColumn Header="Start"
                                                    Binding="{Binding StartedAtLocal}"
                                                    MinWidth="90"
                                                    Width="90" />
                                <DataGridTextColumn Header="End"
                                                    Binding="{Binding EndedAtLocal}"
                                                    MinWidth="90"
                                                    Width="90" />
                                <DataGridTextColumn Header="Duration"
                                                    Binding="{Binding Duration}"
                                                    MinWidth="100"
                                                    Width="100" />
                                <DataGridTextColumn Header="State"
                                                    Binding="{Binding State}"
                                                    MinWidth="80"
                                                    Width="80" />
                                <DataGridTextColumn Header="Window"
                                                    Binding="{Binding WindowTitle}"
                                                    MinWidth="260"
                                                    Width="260" />
                                <DataGridTextColumn Header="Source"
                                                    Binding="{Binding Source}"
                                                    MinWidth="100"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Tag="{x:Static dashboard:DetailsTab.WebSessions}"
                         AutomationProperties.AutomationId="WebSessionsTab"
                         AutomationProperties.Name="Web Sessions">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock AutomationProperties.AutomationId="WebSessionsTabIcon"
                                       Text="◎"
                                       Style="{StaticResource TabHeaderIconTextStyle}" />
                            <TextBlock Text="Web Sessions" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid AutomationProperties.AutomationId="WebSessionsList">
                        <DataGrid AutomationProperties.AutomationId="RecentWebSessionsList"
                                  AutomationProperties.Name="Recent web sessions"
                                  Style="{StaticResource SessionDataGridStyle}"
                                  ItemsSource="{Binding VisibleWebSessionRows}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Domain"
                                                    Binding="{Binding Domain}"
                                                    MinWidth="180"
                                                    Width="180" />
                                <DataGridTextColumn Header="Title"
                                                    Binding="{Binding PageTitle}"
                                                    MinWidth="260"
                                                    Width="260" />
                                <DataGridTextColumn Header="URL Mode"
                                                    Binding="{Binding UrlMode}"
                                                    MinWidth="120"
                                                    Width="120" />
                                <DataGridTextColumn Header="Start"
                                                    Binding="{Binding StartedAtLocal}"
                                                    MinWidth="90"
                                                    Width="90" />
                                <DataGridTextColumn Header="End"
                                                    Binding="{Binding EndedAtLocal}"
                                                    MinWidth="90"
                                                    Width="90" />
                                <DataGridTextColumn Header="Duration"
                                                    Binding="{Binding Duration}"
                                                    MinWidth="100"
                                                    Width="100" />
                                <DataGridTextColumn Header="Browser"
                                                    Binding="{Binding Browser}"
                                                    MinWidth="120"
                                                    Width="120" />
                                <DataGridTextColumn Header="Confidence"
                                                    Binding="{Binding Confidence}"
                                                    MinWidth="100"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Tag="{x:Static dashboard:DetailsTab.LiveEventLog}"
                         AutomationProperties.AutomationId="LiveEventsTab"
                         AutomationProperties.Name="Live Event Log">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock AutomationProperties.AutomationId="LiveEventsTabIcon"
                                       Text="≡"
                                       Style="{StaticResource TabHeaderIconTextStyle}" />
                            <TextBlock Text="Live Event Log" />
                        </StackPanel>
                    </TabItem.Header>
                    <DataGrid AutomationProperties.AutomationId="LiveEventsList"
                              AutomationProperties.Name="Live event log"
                              Style="{StaticResource SessionDataGridStyle}"
                              ItemsSource="{Binding VisibleLiveEventRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"
                                                Binding="{Binding OccurredAtLocal}"
                                                MinWidth="100"
                                                Width="100" />
                            <DataGridTextColumn Header="Event Type"
                                                Binding="{Binding EventType}"
                                                MinWidth="130"
                                                Width="130" />
                            <DataGridTextColumn Header="App"
                                                Binding="{Binding AppName}"
                                                MinWidth="160"
                                                Width="160" />
                            <DataGridTextColumn Header="Domain"
                                                Binding="{Binding Domain}"
                                                MinWidth="160"
                                                Width="160" />
                            <DataGridTextColumn Header="Message"
                                                Binding="{Binding Message}"
                                                MinWidth="260"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Tag="{x:Static dashboard:DetailsTab.Settings}"
                         AutomationProperties.AutomationId="SettingsTab"
                         AutomationProperties.Name="Settings">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock AutomationProperties.AutomationId="SettingsTabIcon"
                                       Text="⚙"
                                       Style="{StaticResource TabHeaderIconTextStyle}" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:SettingsPanel />
                </TabItem>
            </TabControl>

            <DockPanel Grid.Row="1"
                       Margin="0,12,0,0"
                       LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <TextBlock Text="Rows per page:"
                               VerticalAlignment="Center"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,8,0" />
                    <ComboBox AutomationProperties.AutomationId="DetailsRowsPerPageComboBox"
                              AutomationProperties.Name="Rows per details page"
                              ItemsSource="{Binding RowsPerPageOptions}"
                              SelectedItem="{Binding RowsPerPage, Mode=TwoWay}"
                              MinWidth="72" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button AutomationProperties.AutomationId="DetailsPreviousPageButton"
                            AutomationProperties.Name="Previous details page"
                            Content="‹"
                            Command="{Binding PreviousDetailsPageCommand}"
                            Style="{StaticResource PagerIconButtonStyle}" />
                    <TextBlock AutomationProperties.AutomationId="DetailsPageStatusText"
                               AutomationProperties.Name="Current details page"
                               Text="{Binding DetailsPageText}"
                               VerticalAlignment="Center"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="8,0" />
                    <Button AutomationProperties.AutomationId="DetailsNextPageButton"
                            AutomationProperties.Name="Next details page"
                            Content="›"
                            Command="{Binding NextDetailsPageCommand}"
                            Style="{StaticResource PagerIconButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>

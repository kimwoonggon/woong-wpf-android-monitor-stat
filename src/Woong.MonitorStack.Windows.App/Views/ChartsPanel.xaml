<UserControl x:Class="Woong.MonitorStack.Windows.App.Views.ChartsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Woong.MonitorStack.Windows.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dashboard="clr-namespace:Woong.MonitorStack.Windows.Presentation.Dashboard;assembly=Woong.MonitorStack.Windows.Presentation"
             mc:Ignorable="d"
             AutomationProperties.AutomationId="ChartArea"
             d:DataContext="{d:DesignInstance dashboard:DashboardViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Buttons.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <controls:SectionCard>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="230" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="시간대별 Active Focus"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#162033" />
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="앱별 집중 시간"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#162033"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        AutomationProperties.AutomationId="AppChartDetailsButton"
                        Content="상세보기"
                        Command="{Binding ShowAppFocusDetailsCommand}"
                        Margin="8,0,18,0"
                        Style="{StaticResource CompactActionButtonStyle}" />
            </Grid>
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="도메인별 집중 시간"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#162033"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        AutomationProperties.AutomationId="DomainChartDetailsButton"
                        Content="상세보기"
                        Command="{Binding ShowDomainFocusDetailsCommand}"
                        Style="{StaticResource CompactActionButtonStyle}" />
            </Grid>

            <lvc:CartesianChart Grid.Row="1"
                                AutomationProperties.AutomationId="HourlyActivityChart"
                                Margin="0,12,18,0"
                                Series="{Binding HourlyActivityChart.Series}"
                                XAxes="{Binding HourlyActivityChart.XAxes}"
                                YAxes="{Binding HourlyActivityChart.YAxes}" />
            <controls:EmptyState Grid.Row="1"
                                 Text="{Binding HourlyActivityChart.EmptyStateText}"
                                 TextAutomationId="HourlyActivityEmptyStateText" />
            <lvc:CartesianChart Grid.Row="1"
                                Grid.Column="1"
                                AutomationProperties.AutomationId="AppUsageChart"
                                Margin="0,12,18,0"
                                Series="{Binding AppUsageChart.Series}"
                                XAxes="{Binding AppUsageChart.XAxes}"
                                YAxes="{Binding AppUsageChart.YAxes}" />
            <controls:EmptyState Grid.Row="1"
                                 Grid.Column="1"
                                 Text="{Binding AppUsageChart.EmptyStateText}"
                                 TextAutomationId="AppUsageEmptyStateText" />
            <lvc:CartesianChart Grid.Row="1"
                                Grid.Column="2"
                                AutomationProperties.AutomationId="DomainUsageChart"
                                Margin="0,12,0,0"
                                Series="{Binding DomainUsageChart.Series}"
                                XAxes="{Binding DomainUsageChart.XAxes}"
                                YAxes="{Binding DomainUsageChart.YAxes}" />
            <controls:EmptyState Grid.Row="1"
                                 Grid.Column="2"
                                 Text="{Binding DomainUsageChart.EmptyStateText}"
                                 TextAutomationId="DomainUsageEmptyStateText" />
        </Grid>
    </controls:SectionCard>
</UserControl>

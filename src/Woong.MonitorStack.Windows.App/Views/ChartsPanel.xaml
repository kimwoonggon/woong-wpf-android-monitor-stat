<UserControl x:Class="Woong.MonitorStack.Windows.App.Views.ChartsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Woong.MonitorStack.Windows.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dashboard="clr-namespace:Woong.MonitorStack.Windows.Presentation.Dashboard;assembly=Woong.MonitorStack.Windows.Presentation"
             mc:Ignorable="d"
             AutomationProperties.AutomationId="ChartsPanel"
             d:DataContext="{d:DesignInstance dashboard:DashboardViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Colors.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Buttons.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Typography.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <controls:SectionCard AutomationProperties.AutomationId="HourlyChartCard"
                              CardMargin="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="230" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="28"
                            Height="28"
                            CornerRadius="14"
                            Background="{StaticResource MetricBlueBackgroundBrush}"
                            Margin="0,0,8,0">
                        <TextBlock AutomationProperties.AutomationId="HourlyChartIconText"
                                   Text="▥"
                                   Foreground="{StaticResource MetricBlueBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="시간대별 Active Focus"
                               Style="{StaticResource SectionTitleTextStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <lvc:CartesianChart Grid.Row="1"
                                    AutomationProperties.AutomationId="HourlyActivityChart"
                                    Margin="0,12,0,0"
                                    Series="{Binding HourlyActivityChart.Series}"
                                    XAxes="{Binding HourlyActivityChart.XAxes}"
                                    YAxes="{Binding HourlyActivityChart.YAxes}" />
                <controls:EmptyState Grid.Row="1"
                                     Text="{Binding HourlyActivityChart.EmptyStateText}"
                                     TextAutomationId="HourlyActivityEmptyStateText" />
            </Grid>
        </controls:SectionCard>

        <controls:SectionCard Grid.Column="1"
                              AutomationProperties.AutomationId="AppUsageChartCard"
                              CardMargin="8,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="230" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28"
                            Height="28"
                            CornerRadius="14"
                            Background="{StaticResource MetricGreenBackgroundBrush}"
                            Margin="0,0,8,0">
                        <TextBlock AutomationProperties.AutomationId="AppUsageChartIconText"
                                   Text="▰"
                                   Foreground="{StaticResource MetricGreenBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="앱별 집중 시간"
                               Style="{StaticResource SectionTitleTextStyle}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            AutomationProperties.AutomationId="AppChartDetailsButton"
                            AutomationProperties.Name="Show app focus details"
                            Content="상세보기"
                            Command="{Binding ShowAppFocusDetailsCommand}"
                            Margin="8,0,0,0"
                            Style="{StaticResource CompactActionButtonStyle}" />
                </Grid>
                <lvc:CartesianChart Grid.Row="1"
                                    AutomationProperties.AutomationId="AppUsageChart"
                                    Margin="0,12,0,0"
                                    Series="{Binding AppUsageChart.Series}"
                                    XAxes="{Binding AppUsageChart.XAxes}"
                                    YAxes="{Binding AppUsageChart.YAxes}" />
                <controls:EmptyState Grid.Row="1"
                                     Text="{Binding AppUsageChart.EmptyStateText}"
                                     TextAutomationId="AppUsageEmptyStateText" />
            </Grid>
        </controls:SectionCard>

        <controls:SectionCard Grid.Column="2"
                              AutomationProperties.AutomationId="DomainUsageChartCard"
                              CardMargin="8,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="230" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28"
                            Height="28"
                            CornerRadius="14"
                            Background="{StaticResource MetricPurpleBackgroundBrush}"
                            Margin="0,0,8,0">
                        <TextBlock AutomationProperties.AutomationId="DomainUsageChartIconText"
                                   Text="◇"
                                   Foreground="{StaticResource MetricPurpleBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="도메인별 집중 시간"
                               Style="{StaticResource SectionTitleTextStyle}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            AutomationProperties.AutomationId="DomainChartDetailsButton"
                            AutomationProperties.Name="Show domain focus details"
                            Content="상세보기"
                            Command="{Binding ShowDomainFocusDetailsCommand}"
                            Margin="8,0,0,0"
                            Style="{StaticResource CompactActionButtonStyle}" />
                </Grid>
                <lvc:CartesianChart Grid.Row="1"
                                    AutomationProperties.AutomationId="DomainUsageChart"
                                    Margin="0,12,0,0"
                                    Series="{Binding DomainUsageChart.Series}"
                                    XAxes="{Binding DomainUsageChart.XAxes}"
                                    YAxes="{Binding DomainUsageChart.YAxes}" />
                <controls:EmptyState Grid.Row="1"
                                     Text="{Binding DomainUsageChart.EmptyStateText}"
                                     TextAutomationId="DomainUsageEmptyStateText" />
            </Grid>
        </controls:SectionCard>
    </Grid>
</UserControl>

<UserControl x:Class="Woong.MonitorStack.Windows.App.Views.HeaderStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Woong.MonitorStack.Windows.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dashboard="clr-namespace:Woong.MonitorStack.Windows.Presentation.Dashboard;assembly=Woong.MonitorStack.Windows.Presentation"
             mc:Ignorable="d"
             AutomationProperties.AutomationId="HeaderArea"
             d:DataContext="{d:DesignInstance dashboard:DashboardViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Colors.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Typography.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
            <TextBlock Text="Woong Monitor Stack"
                       Style="{StaticResource HeadingTextStyle}" />
            <TextBlock Text="Windows Focus Tracker"
                       Style="{StaticResource SubtitleTextStyle}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <WrapPanel Grid.Column="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center">
            <controls:StatusBadge AutomationProperties.AutomationId="TrackingStatusBadge"
                                  Text="{Binding TrackingBadgeText}"
                                  Background="{StaticResource TrackingBadgeBackgroundBrush}"
                                  BorderBrush="{StaticResource TrackingBadgeBorderBrush}"
                                  TextBrush="{StaticResource TrackingBadgeTextBrush}" />
            <controls:StatusBadge AutomationProperties.AutomationId="SyncStatusBadge"
                                  Text="{Binding SyncBadgeText}"
                                  Background="{StaticResource SyncBadgeBackgroundBrush}"
                                  BorderBrush="{StaticResource SyncBadgeBorderBrush}"
                                  TextBrush="{StaticResource SyncBadgeTextBrush}" />
            <controls:StatusBadge AutomationProperties.AutomationId="PrivacyStatusBadge"
                                  Text="{Binding PrivacyBadgeText}"
                                  Background="{StaticResource PrivacyBadgeBackgroundBrush}"
                                  BorderBrush="{StaticResource PrivacyBadgeBorderBrush}"
                                  TextBrush="{StaticResource PrivacyBadgeTextBrush}" />
        </WrapPanel>
    </Grid>
</UserControl>

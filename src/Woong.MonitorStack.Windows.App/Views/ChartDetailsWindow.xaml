<Window x:Class="Woong.MonitorStack.Windows.App.Views.ChartDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="{Binding Title}"
        Width="1040"
        Height="860"
        MinWidth="860"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Colors.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Typography.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Cards.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Tabs.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock AutomationProperties.AutomationId="ChartDetailsTitleText"
                   Text="{Binding Title}"
                   Style="{StaticResource HeadingTextStyle}" />

        <StackPanel Grid.Row="1"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
            <TextBlock Text="Period"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Style="{StaticResource BodyTextStyle}" />
            <ListBox AutomationProperties.AutomationId="ChartDetailsPeriodSelector"
                     ItemsSource="{Binding PeriodOptions}"
                     SelectedValuePath="Period"
                     SelectedValue="{Binding SelectedPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     BorderThickness="0"
                     Background="{StaticResource TransparentBrush}"
                     ItemContainerStyle="{StaticResource ChartDetailsPeriodSelectorItemStyle}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Style="{StaticResource DashboardCardBorderStyle}">
            <lvc:CartesianChart AutomationProperties.AutomationId="ChartDetailsHorizontalBarChart"
                                Style="{StaticResource ChartDetailsHorizontalBarChartStyle}"
                                Series="{Binding Chart.Series}"
                                XAxes="{Binding Chart.XAxes}"
                                YAxes="{Binding Chart.YAxes}" />
        </Border>

        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Style="{StaticResource DashboardCardBorderStyle}">
            <ListView AutomationProperties.AutomationId="ChartDetailsRowsList"
                      ItemsSource="{Binding DetailRows}"
                      MaxHeight="190">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Label"
                                        Width="560"
                                        DisplayMemberBinding="{Binding Label}" />
                        <GridViewColumn Header="Duration"
                                        Width="160"
                                        DisplayMemberBinding="{Binding DurationText}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</Window>

<UserControl x:Class="Woong.MonitorStack.Windows.App.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dashboard="clr-namespace:Woong.MonitorStack.Windows.Presentation.Dashboard;assembly=Woong.MonitorStack.Windows.Presentation"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             AutomationProperties.AutomationId="SettingsPanel"
             d:DataContext="{d:DesignInstance dashboard:DashboardViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Buttons.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Typography.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Inputs.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Margin="0,0,18,0">
            <TextBlock Text="Privacy"
                       Style="{StaticResource SettingsSectionTitleTextStyle}" />
            <CheckBox Content="Collection visible"
                      AutomationProperties.AutomationId="CollectionVisibleCheckBox"
                      AutomationProperties.Name="Collection visible"
                      IsChecked="{Binding Settings.IsCollectionVisible}"
                      Style="{StaticResource SettingsCheckBoxStyle}" />
            <CheckBox Content="Capture window title"
                      AutomationProperties.AutomationId="WindowTitleVisibleCheckBox"
                      AutomationProperties.Name="Capture window title"
                      IsChecked="{Binding Settings.IsWindowTitleVisible}"
                      Style="{StaticResource SettingsCheckBoxStyle}" />
            <CheckBox Content="Capture page title"
                      AutomationProperties.AutomationId="PageTitleCaptureCheckBox"
                      AutomationProperties.Name="Capture page title"
                      IsEnabled="False"
                      IsChecked="{Binding Settings.IsPageTitleCaptureEnabled}"
                      Style="{StaticResource SettingsCheckBoxStyle}" />
            <CheckBox Content="Full URL capture (off)"
                      AutomationProperties.AutomationId="FullUrlCaptureCheckBox"
                      AutomationProperties.Name="Full URL capture"
                      IsEnabled="False"
                      IsChecked="{Binding Settings.IsFullUrlCaptureEnabled}"
                      Style="{StaticResource SettingsCheckBoxStyle}" />
            <CheckBox Content="Domain-only browser storage"
                      AutomationProperties.AutomationId="DomainOnlyBrowserStorageCheckBox"
                      AutomationProperties.Name="Domain-only browser storage"
                      IsEnabled="False"
                      IsChecked="{Binding Settings.IsDomainOnlyBrowserStorageEnabled}"
                      Style="{StaticResource SettingsCheckBoxStyle}" />
            <TextBlock AutomationProperties.AutomationId="BrowserUrlPrivacyText"
                       Text="Browser URL storage is domain-only by default. Full URLs require explicit future opt-in."
                       Style="{StaticResource SettingsMutedTextStyle}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Margin="0,0,18,0">
            <TextBlock Text="Sync"
                       Style="{StaticResource SettingsSectionTitleTextStyle}" />
            <CheckBox Content="Sync enabled"
                      AutomationProperties.AutomationId="SyncEnabledCheckBox"
                      AutomationProperties.Name="Sync enabled"
                      IsChecked="{Binding Settings.IsSyncEnabled}"
                      Style="{StaticResource SettingsCheckBoxStyle}" />
            <TextBlock AutomationProperties.AutomationId="SyncModeLabel"
                       Text="{Binding Settings.SyncModeLabel}"
                       Style="{StaticResource SettingsMutedTextStyle}" />
            <TextBlock AutomationProperties.AutomationId="SyncStatusLabel"
                       Text="{Binding Settings.SyncStatusLabel}"
                       Style="{StaticResource SettingsWarningTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
            <TextBox AutomationProperties.AutomationId="SyncEndpointTextBox"
                     AutomationProperties.Name="Sync endpoint"
                     Text="{Binding Settings.SyncEndpointText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding Settings.IsSyncEnabled}"
                     Style="{StaticResource SettingsInputTextBoxStyle}"
                     Margin="0,12,0,0" />
        </StackPanel>

        <StackPanel Grid.Column="2">
            <TextBlock Text="Runtime"
                       Style="{StaticResource SettingsSectionTitleTextStyle}" />
            <TextBlock Text="Poll interval: 1 second"
                       Style="{StaticResource SettingsMutedTextStyle}"
                       Margin="0,0,0,8" />
            <TextBlock Text="Idle threshold: 5 minutes"
                       Style="{StaticResource SettingsMutedTextStyle}"
                       Margin="0,0,0,8" />
            <TextBlock Text="Local SQLite DB"
                       Style="{StaticResource SettingsSectionTitleTextStyle}"
                       Margin="0,12,0,4" />
            <TextBlock AutomationProperties.AutomationId="CurrentDatabasePathText"
                       AutomationProperties.Name="Current local database path"
                       Text="{Binding Settings.CurrentDatabasePathText}"
                       Style="{StaticResource SettingsMutedTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
            <TextBlock AutomationProperties.AutomationId="DatabaseStatusLabel"
                       AutomationProperties.Name="Local database status"
                       Text="{Binding Settings.DatabaseStatusLabel}"
                       Style="{StaticResource SettingsWarningTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
            <Button Content="Create / switch DB"
                    AutomationProperties.AutomationId="CreateLocalDatabaseButton"
                    AutomationProperties.Name="Create or switch local SQLite database"
                    Command="{Binding CreateLocalDatabaseCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" />
            <Button Content="Load existing DB"
                    AutomationProperties.AutomationId="LoadExistingLocalDatabaseButton"
                    AutomationProperties.Name="Load existing local SQLite database"
                    Command="{Binding LoadExistingLocalDatabaseCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" />
            <Button Content="Delete local DB"
                    AutomationProperties.AutomationId="DeleteLocalDatabaseButton"
                    AutomationProperties.Name="Delete local SQLite database"
                    Command="{Binding DeleteLocalDatabaseCommand}"
                    IsEnabled="{Binding Settings.CanClearLocalData}"
                    Style="{StaticResource DangerButtonStyle}" />
        </StackPanel>
    </Grid>
</UserControl>

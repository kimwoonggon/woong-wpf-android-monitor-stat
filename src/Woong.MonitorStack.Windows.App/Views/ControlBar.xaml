<UserControl x:Class="Woong.MonitorStack.Windows.App.Views.ControlBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dashboard="clr-namespace:Woong.MonitorStack.Windows.Presentation.Dashboard;assembly=Woong.MonitorStack.Windows.Presentation"
             mc:Ignorable="d"
             AutomationProperties.AutomationId="ControlBar"
             d:DataContext="{d:DesignInstance dashboard:DashboardViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Buttons.xaml" />
                <ResourceDictionary Source="/Woong.MonitorStack.Windows.App;component/Styles/Cards.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource CompactSurfaceBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <WrapPanel Grid.Row="0"
                       AutomationProperties.AutomationId="TrackingActionGroup">
                <Button Content="▶ Start Tracking"
                        AutomationProperties.AutomationId="StartTrackingButton"
                        AutomationProperties.Name="Start tracking"
                        Command="{Binding StartTrackingCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Content="■ Stop Tracking"
                        AutomationProperties.AutomationId="StopTrackingButton"
                        AutomationProperties.Name="Stop tracking"
                        Command="{Binding StopTrackingCommand}"
                        Style="{StaticResource DangerButtonStyle}" />
                <Button Content="↻ Refresh"
                        AutomationProperties.AutomationId="RefreshButton"
                        AutomationProperties.Name="Refresh dashboard"
                        Command="{Binding RefreshDashboardCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="⇅ Sync Now"
                        AutomationProperties.AutomationId="SyncNowButton"
                        AutomationProperties.Name="Sync now"
                        Command="{Binding SyncNowCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </WrapPanel>

            <WrapPanel Grid.Row="0"
                       Grid.Column="1"
                       AutomationProperties.AutomationId="PeriodFilterGroup"
                       HorizontalAlignment="Right">
                <Button Content="Today"
                        AutomationProperties.AutomationId="TodayPeriodButton"
                        AutomationProperties.Name="Show today"
                        Command="{Binding SelectDashboardPeriodCommand}"
                        CommandParameter="{x:Static dashboard:DashboardPeriod.Today}"
                        Style="{StaticResource SelectedPeriodButtonStyle}" />
                <Button Content="1h"
                        AutomationProperties.AutomationId="LastHourPeriodButton"
                        AutomationProperties.Name="Show last hour"
                        Command="{Binding SelectDashboardPeriodCommand}"
                        CommandParameter="{x:Static dashboard:DashboardPeriod.LastHour}"
                        Style="{StaticResource PeriodButtonStyle}" />
                <Button Content="6h"
                        AutomationProperties.AutomationId="Last6HoursPeriodButton"
                        AutomationProperties.Name="Show last 6 hours"
                        Command="{Binding SelectDashboardPeriodCommand}"
                        CommandParameter="{x:Static dashboard:DashboardPeriod.Last6Hours}"
                        Style="{StaticResource PeriodButtonStyle}" />
                <Button Content="24h"
                        AutomationProperties.AutomationId="Last24HoursPeriodButton"
                        AutomationProperties.Name="Show last 24 hours"
                        Command="{Binding SelectDashboardPeriodCommand}"
                        CommandParameter="{x:Static dashboard:DashboardPeriod.Last24Hours}"
                        Style="{StaticResource PeriodButtonStyle}" />
                <Button Content="Custom"
                        AutomationProperties.AutomationId="CustomPeriodButton"
                        AutomationProperties.Name="Show custom range"
                        Command="{Binding SelectDashboardPeriodCommand}"
                        CommandParameter="{x:Static dashboard:DashboardPeriod.Custom}"
                        Style="{StaticResource PeriodButtonStyle}" />
            </WrapPanel>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,12,0,0"
                    Padding="12"
                    Background="{StaticResource AppBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding IsCustomRangeEditorVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <WrapPanel AutomationProperties.AutomationId="CustomRangeEditor"
                           VerticalAlignment="Center">
                    <TextBlock Text="Custom range"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <TextBlock Text="Start"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <DatePicker SelectedDate="{Binding CustomStartDate, Mode=TwoWay}"
                                AutomationProperties.AutomationId="CustomStartDatePicker"
                                AutomationProperties.Name="Custom range start date"
                                Width="140"
                                Margin="0,0,6,0" />
                    <TextBox Text="{Binding CustomStartTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="CustomStartTimeTextBox"
                             AutomationProperties.Name="Custom range start time"
                             Width="64"
                             MinHeight="34"
                             Margin="0,0,14,0" />
                    <TextBlock Text="End"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <DatePicker SelectedDate="{Binding CustomEndDate, Mode=TwoWay}"
                                AutomationProperties.AutomationId="CustomEndDatePicker"
                                AutomationProperties.Name="Custom range end date"
                                Width="140"
                                Margin="0,0,6,0" />
                    <TextBox Text="{Binding CustomEndTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="CustomEndTimeTextBox"
                             AutomationProperties.Name="Custom range end time"
                             Width="64"
                             MinHeight="34"
                             Margin="0,0,14,0" />
                    <Button Content="Apply"
                            AutomationProperties.AutomationId="ApplyCustomRangeButton"
                            AutomationProperties.Name="Apply custom range"
                            Command="{Binding ApplyCustomRangeCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <TextBlock Text="{Binding CustomRangeStatusText}"
                               AutomationProperties.AutomationId="CustomRangeStatusText"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="12,0,0,0" />
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

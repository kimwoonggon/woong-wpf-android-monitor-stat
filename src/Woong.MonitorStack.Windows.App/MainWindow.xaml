<Window x:Class="Woong.MonitorStack.Windows.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dashboard="clr-namespace:Woong.MonitorStack.Windows.Presentation.Dashboard;assembly=Woong.MonitorStack.Windows.Presentation"
        mc:Ignorable="d"
        Title="Woong Monitor Stack"
        AutomationProperties.AutomationId="MainWindow"
        Width="1180"
        Height="780"
        MinWidth="1024"
        MinHeight="768"
        Background="#F6F8FB"
        d:DataContext="{d:DesignInstance dashboard:DashboardViewModel, IsDesignTimeCreatable=False}">
    <Window.Resources>
        <Style x:Key="DashboardButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="8,0,0,8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  AutomationProperties.AutomationId="HeaderArea"
                  Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Woong Monitor Stack"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#162033" />
                    <TextBlock Text="Windows Focus Tracker"
                               FontSize="13"
                               Foreground="#5A6472"
                               Margin="0,4,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Border AutomationProperties.AutomationId="TrackingStatusBadge"
                            Style="{StaticResource StatusBadgeStyle}"
                            Background="#EEF8F1"
                            BorderBrush="#BFE8CC">
                        <TextBlock Text="{Binding TrackingBadgeText}"
                                   Foreground="#087A34"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border AutomationProperties.AutomationId="SyncStatusBadge"
                            Style="{StaticResource StatusBadgeStyle}"
                            Background="#FFF6E8"
                            BorderBrush="#FFDDA8">
                        <TextBlock Text="{Binding SyncBadgeText}"
                                   Foreground="#A45B00"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border AutomationProperties.AutomationId="PrivacyStatusBadge"
                            Style="{StaticResource StatusBadgeStyle}"
                            Background="#EEF5FF"
                            BorderBrush="#BFD8FF">
                        <TextBlock Text="{Binding PrivacyBadgeText}"
                                   Foreground="#0B63CE"
                                   FontWeight="SemiBold" />
                    </Border>
                </WrapPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,0,0,16"
                    Padding="12"
                    CornerRadius="8"
                    Background="White"
                    BorderBrush="#DCE1E8"
                    BorderThickness="1">
                <WrapPanel AutomationProperties.AutomationId="PeriodSelector">
                    <Button Content="Start Tracking"
                            AutomationProperties.AutomationId="StartTrackingButton"
                            Command="{Binding StartTrackingCommand}"
                            Style="{StaticResource DashboardButtonStyle}" />
                    <Button Content="Stop Tracking"
                            AutomationProperties.AutomationId="StopTrackingButton"
                            Command="{Binding StopTrackingCommand}"
                            Style="{StaticResource DashboardButtonStyle}" />
                    <Button Content="Refresh"
                            AutomationProperties.AutomationId="RefreshButton"
                            Command="{Binding RefreshDashboardCommand}"
                            Style="{StaticResource DashboardButtonStyle}" />
                    <Button Content="Sync Now"
                            AutomationProperties.AutomationId="SyncNowButton"
                            Command="{Binding SyncNowCommand}"
                            Style="{StaticResource DashboardButtonStyle}" />
                    <Button Content="Today"
                            AutomationProperties.AutomationId="TodayPeriodButton"
                            Command="{Binding SelectDashboardPeriodCommand}"
                            CommandParameter="{x:Static dashboard:DashboardPeriod.Today}"
                            Style="{StaticResource DashboardButtonStyle}" />
                    <Button Content="1h"
                            AutomationProperties.AutomationId="LastHourPeriodButton"
                            Command="{Binding SelectDashboardPeriodCommand}"
                            CommandParameter="{x:Static dashboard:DashboardPeriod.LastHour}"
                            Style="{StaticResource DashboardButtonStyle}" />
                    <Button Content="6h"
                            AutomationProperties.AutomationId="Last6HoursPeriodButton"
                            Command="{Binding SelectDashboardPeriodCommand}"
                            CommandParameter="{x:Static dashboard:DashboardPeriod.Last6Hours}"
                            Style="{StaticResource DashboardButtonStyle}" />
                    <Button Content="24h"
                            AutomationProperties.AutomationId="Last24HoursPeriodButton"
                            Command="{Binding SelectDashboardPeriodCommand}"
                            CommandParameter="{x:Static dashboard:DashboardPeriod.Last24Hours}"
                            Style="{StaticResource DashboardButtonStyle}" />
                    <Button Content="Custom"
                            AutomationProperties.AutomationId="CustomPeriodButton"
                            Command="{Binding SelectDashboardPeriodCommand}"
                            CommandParameter="{x:Static dashboard:DashboardPeriod.Custom}"
                            Style="{StaticResource DashboardButtonStyle}" />
                </WrapPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,0,0,16"
                    Padding="18"
                    CornerRadius="8"
                    Background="White"
                    BorderBrush="#DCE1E8"
                    BorderThickness="1">
                <StackPanel AutomationProperties.AutomationId="CurrentActivityPanel">
                    <TextBlock Text="Current Focus"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#162033"
                               Margin="0,0,0,14" />
                    <UniformGrid Columns="3">
                        <StackPanel Margin="0,0,18,12">
                            <TextBlock Text="Tracking status"
                                       Foreground="#5A6472"
                                       FontSize="12" />
                            <TextBlock AutomationProperties.AutomationId="TrackingStatusText"
                                       Text="{Binding TrackingStatusText}"
                                       Foreground="#162033"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,18,12">
                            <TextBlock Text="Current app"
                                       Foreground="#5A6472"
                                       FontSize="12" />
                            <TextBlock AutomationProperties.AutomationId="CurrentAppNameText"
                                       Text="{Binding CurrentAppNameText}"
                                       Foreground="#162033"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Current process"
                                       Foreground="#5A6472"
                                       FontSize="12" />
                            <TextBlock AutomationProperties.AutomationId="CurrentProcessNameText"
                                       Text="{Binding CurrentProcessNameText}"
                                       Foreground="#162033"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Margin="0,0,18,12">
                            <TextBlock Text="Current window title"
                                       Foreground="#5A6472"
                                       FontSize="12" />
                            <TextBlock AutomationProperties.AutomationId="CurrentWindowTitleText"
                                       Text="{Binding CurrentWindowTitleText}"
                                       Foreground="#162033"
                                       FontSize="14"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,0,18,12">
                            <TextBlock Text="Current browser domain"
                                       Foreground="#5A6472"
                                       FontSize="12" />
                            <TextBlock AutomationProperties.AutomationId="CurrentBrowserDomainText"
                                       Text="{Binding CurrentBrowserDomainText}"
                                       Foreground="#162033"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Current session duration"
                                       Foreground="#5A6472"
                                       FontSize="12" />
                            <TextBlock AutomationProperties.AutomationId="CurrentSessionDurationText"
                                       Text="{Binding CurrentSessionDurationText}"
                                       Foreground="#162033"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="Last persisted session"
                                       Foreground="#5A6472"
                                       FontSize="12" />
                            <TextBlock AutomationProperties.AutomationId="LastPersistedSessionText"
                                       Text="{Binding LastPersistedSessionText}"
                                       Foreground="#162033"
                                       FontSize="14"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="Last poll time"
                                       Foreground="#5A6472"
                                       FontSize="12" />
                            <TextBlock AutomationProperties.AutomationId="LastPollTimeText"
                                       Text="{Binding LastPollTimeText}"
                                       Foreground="#162033"
                                       FontSize="14" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Last DB write / Sync state"
                                       Foreground="#5A6472"
                                       FontSize="12" />
                            <TextBlock AutomationProperties.AutomationId="LastDbWriteTimeText"
                                       Text="{Binding LastDbWriteTimeText}"
                                       Foreground="#162033"
                                       FontSize="14" />
                            <TextBlock AutomationProperties.AutomationId="LastSyncStatusText"
                                       Text="{Binding LastSyncStatusText}"
                                       Foreground="#5A6472"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <ItemsControl Grid.Row="3"
                          AutomationProperties.AutomationId="SummaryCardsContainer"
                          ItemsSource="{Binding SummaryCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type dashboard:DashboardSummaryCard}">
                        <Border Margin="0,0,8,12"
                                Padding="18"
                                CornerRadius="8"
                                Background="White"
                                BorderBrush="#DCE1E8"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}"
                                           Foreground="#162033"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Value}"
                                           Foreground="#162033"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />
                                <TextBlock Text="{Binding Subtitle}"
                                           Foreground="#5A6472"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="4">
                <Border Margin="0,4,0,16"
                        Padding="18"
                        CornerRadius="8"
                        Background="White"
                        BorderBrush="#DCE1E8"
                        BorderThickness="1"
                        AutomationProperties.AutomationId="ChartArea">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="230" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="시간대별 Active Focus"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#162033" />
                        <TextBlock Grid.Column="1"
                                   Text="앱별 집중 시간"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#162033" />
                        <TextBlock Grid.Column="2"
                                   Text="도메인별 집중 시간"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#162033" />

                        <lvc:CartesianChart Grid.Row="1"
                                            AutomationProperties.AutomationId="HourlyActivityChart"
                                            Margin="0,12,18,0"
                                            Series="{Binding HourlyActivityChart.Series}" />
                        <lvc:CartesianChart Grid.Row="1"
                                            Grid.Column="1"
                                            AutomationProperties.AutomationId="AppUsageChart"
                                            Margin="0,12,18,0"
                                            Series="{Binding AppUsageChart.Series}" />
                        <lvc:PieChart Grid.Row="1"
                                      Grid.Column="2"
                                      AutomationProperties.AutomationId="DomainUsageChart"
                                      Margin="0,12,0,0"
                                      Series="{Binding DomainUsageSeries}" />
                    </Grid>
                </Border>

                <Border Padding="18"
                        CornerRadius="8"
                        Background="White"
                        BorderBrush="#DCE1E8"
                        BorderThickness="1">
                    <TabControl AutomationProperties.AutomationId="DashboardTabs">
                        <TabItem Header="App Sessions"
                                 AutomationProperties.AutomationId="AppSessionsTab">
                            <DataGrid Margin="0,12,0,0"
                                      AutomationProperties.AutomationId="RecentAppSessionsList"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      MinHeight="260"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding RecentSessions}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="App"
                                                        Binding="{Binding AppName}"
                                                        MinWidth="160"
                                                        Width="160" />
                                    <DataGridTextColumn Header="Process"
                                                        Binding="{Binding ProcessName}"
                                                        MinWidth="180"
                                                        Width="180" />
                                    <DataGridTextColumn Header="Start"
                                                        Binding="{Binding StartedAtLocal}"
                                                        MinWidth="90"
                                                        Width="90" />
                                    <DataGridTextColumn Header="End"
                                                        Binding="{Binding EndedAtLocal}"
                                                        MinWidth="90"
                                                        Width="90" />
                                    <DataGridTextColumn Header="Duration"
                                                        Binding="{Binding Duration}"
                                                        MinWidth="100"
                                                        Width="100" />
                                    <DataGridTextColumn Header="State"
                                                        Binding="{Binding State}"
                                                        MinWidth="80"
                                                        Width="80" />
                                    <DataGridTextColumn Header="Window"
                                                        Binding="{Binding WindowTitle}"
                                                        MinWidth="260"
                                                        Width="260" />
                                    <DataGridTextColumn Header="Source"
                                                        Binding="{Binding Source}"
                                                        MinWidth="100"
                                                        Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Web Sessions"
                                 AutomationProperties.AutomationId="WebSessionsTab">
                            <DataGrid Margin="0,12,0,0"
                                      AutomationProperties.AutomationId="RecentWebSessionsList"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      MinHeight="260"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding RecentWebSessions}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Domain"
                                                        Binding="{Binding Domain}"
                                                        MinWidth="180"
                                                        Width="180" />
                                    <DataGridTextColumn Header="Title"
                                                        Binding="{Binding PageTitle}"
                                                        MinWidth="260"
                                                        Width="260" />
                                    <DataGridTextColumn Header="URL Mode"
                                                        Binding="{Binding UrlMode}"
                                                        MinWidth="120"
                                                        Width="120" />
                                    <DataGridTextColumn Header="Start"
                                                        Binding="{Binding StartedAtLocal}"
                                                        MinWidth="90"
                                                        Width="90" />
                                    <DataGridTextColumn Header="End"
                                                        Binding="{Binding EndedAtLocal}"
                                                        MinWidth="90"
                                                        Width="90" />
                                    <DataGridTextColumn Header="Duration"
                                                        Binding="{Binding Duration}"
                                                        MinWidth="100"
                                                        Width="100" />
                                    <DataGridTextColumn Header="Browser"
                                                        Binding="{Binding Browser}"
                                                        MinWidth="120"
                                                        Width="120" />
                                    <DataGridTextColumn Header="Confidence"
                                                        Binding="{Binding Confidence}"
                                                        MinWidth="100"
                                                        Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Live Event Log"
                                 AutomationProperties.AutomationId="LiveEventsTab">
                            <DataGrid Margin="0,12,0,0"
                                      AutomationProperties.AutomationId="LiveEventsList"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      MinHeight="260"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding LiveEvents}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time"
                                                        Binding="{Binding OccurredAtLocal}"
                                                        MinWidth="100"
                                                        Width="100" />
                                    <DataGridTextColumn Header="Event Type"
                                                        Binding="{Binding EventType}"
                                                        MinWidth="130"
                                                        Width="130" />
                                    <DataGridTextColumn Header="App"
                                                        Binding="{Binding AppName}"
                                                        MinWidth="160"
                                                        Width="160" />
                                    <DataGridTextColumn Header="Domain"
                                                        Binding="{Binding Domain}"
                                                        MinWidth="160"
                                                        Width="160" />
                                    <DataGridTextColumn Header="Message"
                                                        Binding="{Binding Message}"
                                                        MinWidth="260"
                                                        Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Settings"
                                 AutomationProperties.AutomationId="SettingsTab">
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Text="Privacy"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               Foreground="#162033"
                                               Margin="0,0,0,10" />
                                    <CheckBox Content="Collection visible"
                                              AutomationProperties.AutomationId="CollectionVisibleCheckBox"
                                              IsChecked="{Binding Settings.IsCollectionVisible}"
                                              FontSize="14"
                                              Margin="0,0,0,10" />
                                    <CheckBox Content="Capture window title"
                                              AutomationProperties.AutomationId="WindowTitleVisibleCheckBox"
                                              IsChecked="{Binding Settings.IsWindowTitleVisible}"
                                              FontSize="14"
                                              Margin="0,0,0,10" />
                                    <CheckBox Content="Full URL capture (off)"
                                              AutomationProperties.AutomationId="FullUrlCaptureCheckBox"
                                              IsEnabled="False"
                                              IsChecked="False"
                                              FontSize="14"
                                              Margin="0,0,0,10" />
                                    <TextBlock AutomationProperties.AutomationId="BrowserUrlPrivacyText"
                                               Text="Browser URL storage is domain-only by default. Full URLs require explicit future opt-in."
                                               Foreground="#5A6472"
                                               FontSize="13"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="0,0,18,0">
                                    <TextBlock Text="Sync"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               Foreground="#162033"
                                               Margin="0,0,0,10" />
                                    <CheckBox Content="Sync enabled"
                                              AutomationProperties.AutomationId="SyncEnabledCheckBox"
                                              IsChecked="{Binding Settings.IsSyncEnabled}"
                                              FontSize="14"
                                              Margin="0,0,0,10" />
                                    <TextBlock AutomationProperties.AutomationId="SyncModeLabel"
                                               Text="{Binding Settings.SyncModeLabel}"
                                               Foreground="#5A6472"
                                               FontSize="13" />
                                    <TextBlock AutomationProperties.AutomationId="SyncStatusLabel"
                                               Text="{Binding Settings.SyncStatusLabel}"
                                               Foreground="#8A4B00"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Runtime"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               Foreground="#162033"
                                               Margin="0,0,0,10" />
                                    <TextBlock Text="Poll interval: 1 second"
                                               Foreground="#5A6472"
                                               FontSize="13"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Idle threshold: 5 minutes"
                                               Foreground="#5A6472"
                                               FontSize="13"
                                               Margin="0,0,0,8" />
                                    <Button Content="Open local DB folder"
                                            AutomationProperties.AutomationId="OpenLocalDbFolderButton"
                                            IsEnabled="False"
                                            Style="{StaticResource DashboardButtonStyle}" />
                                    <Button Content="Open logs folder"
                                            AutomationProperties.AutomationId="OpenLogsFolderButton"
                                            IsEnabled="False"
                                            Style="{StaticResource DashboardButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>

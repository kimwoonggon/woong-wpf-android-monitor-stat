<Window x:Class="Woong.MonitorStack.Windows.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dashboard="clr-namespace:Woong.MonitorStack.Windows.Presentation.Dashboard;assembly=Woong.MonitorStack.Windows.Presentation"
        mc:Ignorable="d"
        Title="Woong Monitor Stack"
        Width="1040"
        Height="680"
        MinWidth="860"
        MinHeight="560"
        Background="#F6F7F9"
        d:DataContext="{d:DesignInstance dashboard:DashboardViewModel, IsDesignTimeCreatable=False}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <TextBlock Text="Woong Monitor Stack"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#18202A" />
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding TopAppName, TargetNullValue=''}"
                       FontSize="14"
                       Foreground="#5A6472"
                       VerticalAlignment="Center" />
        </DockPanel>

        <StackPanel Grid.Row="1"
                    Margin="0,20,0,18"
                    Orientation="Horizontal">
            <Button Content="Today"
                    Command="{Binding SelectDashboardPeriodCommand}"
                    CommandParameter="{x:Static dashboard:DashboardPeriod.Today}"
                    Padding="14,8"
                    Margin="0,0,8,0" />
            <Button Content="1h"
                    Command="{Binding SelectDashboardPeriodCommand}"
                    CommandParameter="{x:Static dashboard:DashboardPeriod.LastHour}"
                    Padding="14,8"
                    Margin="0,0,8,0" />
            <Button Content="6h"
                    Command="{Binding SelectDashboardPeriodCommand}"
                    CommandParameter="{x:Static dashboard:DashboardPeriod.Last6Hours}"
                    Padding="14,8"
                    Margin="0,0,8,0" />
            <Button Content="24h"
                    Command="{Binding SelectDashboardPeriodCommand}"
                    CommandParameter="{x:Static dashboard:DashboardPeriod.Last24Hours}"
                    Padding="14,8" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ItemsControl ItemsSource="{Binding SummaryCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type dashboard:DashboardSummaryCard}">
                        <Border Margin="0,0,12,0"
                                Padding="18"
                                CornerRadius="8"
                                Background="White"
                                BorderBrush="#DCE1E8"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}"
                                           Foreground="#5A6472"
                                           FontSize="13" />
                                <TextBlock Text="{Binding Value}"
                                           Foreground="#18202A"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="1"
                    Margin="0,22,0,0"
                    Padding="18"
                    CornerRadius="8"
                    Background="White"
                    BorderBrush="#DCE1E8"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Activity"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#18202A" />
                    <TextBlock Grid.Column="1"
                               Text="Domains"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#18202A" />

                    <lvc:CartesianChart Grid.Row="1"
                                        MinHeight="220"
                                        Series="{Binding HourlyActivityChart.Series}" />
                    <lvc:PieChart Grid.Row="1"
                                  Grid.Column="1"
                                  MinHeight="220"
                                  Series="{Binding DomainUsageSeries}" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,16,0,0"
                    Padding="18"
                    CornerRadius="8"
                    Background="White"
                    BorderBrush="#DCE1E8"
                    BorderThickness="1">
                <TabControl>
                    <TabItem Header="App Sessions">
                        <DataGrid Margin="0,12,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding RecentSessions}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="App"
                                                    Binding="{Binding AppName}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Started"
                                                    Binding="{Binding StartedAtLocal}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Duration"
                                                    Binding="{Binding Duration}"
                                                    Width="110" />
                                <DataGridCheckBoxColumn Header="Idle"
                                                        Binding="{Binding IsIdle}"
                                                        Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Web Sessions">
                        <DataGrid Margin="0,12,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding RecentWebSessions}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Domain"
                                                    Binding="{Binding Domain}"
                                                    Width="180" />
                                <DataGridTextColumn Header="Page"
                                                    Binding="{Binding PageTitle}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Started"
                                                    Binding="{Binding StartedAtLocal}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Duration"
                                                    Binding="{Binding Duration}"
                                                    Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Live Event Log">
                        <DataGrid Margin="0,12,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding LiveEvents}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time"
                                                    Binding="{Binding OccurredAtLocal}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Kind"
                                                    Binding="{Binding Kind}"
                                                    Width="120" />
                                <DataGridTextColumn Header="Message"
                                                    Binding="{Binding Message}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>

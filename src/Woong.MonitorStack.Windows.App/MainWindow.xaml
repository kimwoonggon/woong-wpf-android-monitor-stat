<Window x:Class="Woong.MonitorStack.Windows.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dashboard="clr-namespace:Woong.MonitorStack.Windows.Presentation.Dashboard;assembly=Woong.MonitorStack.Windows.Presentation"
        mc:Ignorable="d"
        Title="Woong Monitor Stack"
        AutomationProperties.AutomationId="MainWindow"
        Width="860"
        Height="680"
        MinWidth="860"
        MinHeight="560"
        Background="#F6F7F9"
        d:DataContext="{d:DesignInstance dashboard:DashboardViewModel, IsDesignTimeCreatable=False}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <TextBlock Text="Woong Monitor Stack"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#18202A" />
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding TopAppName, TargetNullValue=''}"
                       FontSize="14"
                       Foreground="#5A6472"
                       VerticalAlignment="Center" />
        </DockPanel>

        <StackPanel Grid.Row="1"
                    Margin="0,20,0,18"
                    AutomationProperties.AutomationId="PeriodSelector"
                    Orientation="Horizontal">
            <Button Content="Start"
                    AutomationProperties.AutomationId="StartTrackingButton"
                    Command="{Binding StartTrackingCommand}"
                    Padding="14,8"
                    Margin="0,0,8,0" />
            <Button Content="Stop"
                    AutomationProperties.AutomationId="StopTrackingButton"
                    Command="{Binding StopTrackingCommand}"
                    Padding="14,8"
                    Margin="0,0,8,0" />
            <Button Content="Sync Now"
                    AutomationProperties.AutomationId="SyncNowButton"
                    Command="{Binding SyncNowCommand}"
                    Padding="14,8"
                    Margin="0,0,16,0" />
            <Button Content="Refresh"
                    AutomationProperties.AutomationId="RefreshButton"
                    Command="{Binding RefreshDashboardCommand}"
                    Padding="14,8"
                    Margin="0,0,16,0" />
            <Button Content="Today"
                    AutomationProperties.AutomationId="TodayPeriodButton"
                    Command="{Binding SelectDashboardPeriodCommand}"
                    CommandParameter="{x:Static dashboard:DashboardPeriod.Today}"
                    Padding="14,8"
                    Margin="0,0,8,0" />
            <Button Content="1h"
                    AutomationProperties.AutomationId="LastHourPeriodButton"
                    Command="{Binding SelectDashboardPeriodCommand}"
                    CommandParameter="{x:Static dashboard:DashboardPeriod.LastHour}"
                    Padding="14,8"
                    Margin="0,0,8,0" />
            <Button Content="6h"
                    AutomationProperties.AutomationId="Last6HoursPeriodButton"
                    Command="{Binding SelectDashboardPeriodCommand}"
                    CommandParameter="{x:Static dashboard:DashboardPeriod.Last6Hours}"
                    Padding="14,8"
                    Margin="0,0,8,0" />
            <Button Content="24h"
                    AutomationProperties.AutomationId="Last24HoursPeriodButton"
                    Command="{Binding SelectDashboardPeriodCommand}"
                    CommandParameter="{x:Static dashboard:DashboardPeriod.Last24Hours}"
                    Padding="14,8" />
        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,0,0,18"
                Padding="18"
                CornerRadius="8"
                Background="White"
                BorderBrush="#DCE1E8"
                BorderThickness="1">
            <Grid AutomationProperties.AutomationId="CurrentActivityPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Tracking"
                               Foreground="#5A6472"
                               FontSize="12" />
                    <TextBlock AutomationProperties.AutomationId="TrackingStatusText"
                               Text="{Binding TrackingStatusText}"
                               Foreground="#18202A"
                               FontSize="18"
                               FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="0,0,16,0">
                    <TextBlock Text="Current app"
                               Foreground="#5A6472"
                               FontSize="12" />
                    <TextBlock AutomationProperties.AutomationId="CurrentAppNameText"
                               Text="{Binding CurrentAppNameText}"
                               Foreground="#18202A"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock AutomationProperties.AutomationId="CurrentProcessNameText"
                               Text="{Binding CurrentProcessNameText}"
                               Foreground="#5A6472"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Margin="0,0,16,0">
                    <TextBlock Text="Window title"
                               Foreground="#5A6472"
                               FontSize="12" />
                    <TextBlock AutomationProperties.AutomationId="CurrentWindowTitleText"
                               Text="{Binding CurrentWindowTitleText}"
                               Foreground="#18202A"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Margin="0,14,16,0"
                           AutomationProperties.AutomationId="LastPersistedSessionText"
                           Text="{Binding LastPersistedSessionText}"
                           Foreground="#5A6472"
                           FontSize="13"
                           TextWrapping="Wrap" />
                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,14,16,0">
                    <TextBlock Text="Duration"
                               Foreground="#5A6472"
                               FontSize="12" />
                    <TextBlock AutomationProperties.AutomationId="CurrentSessionDurationText"
                               Text="{Binding CurrentSessionDurationText}"
                               Foreground="#18202A"
                               FontSize="16"
                               FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Margin="0,14,0,0"
                           AutomationProperties.AutomationId="LastSyncStatusText"
                           Text="{Binding LastSyncStatusText}"
                           Foreground="#5A6472"
                           FontSize="13"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ItemsControl AutomationProperties.AutomationId="SummaryCardsContainer"
                          ClipToBounds="True"
                          HorizontalAlignment="Left"
                          Width="786"
                          ItemsSource="{Binding SummaryCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"
                                     Width="786" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type dashboard:DashboardSummaryCard}">
                        <Border Width="250"
                                Margin="0,0,12,0"
                                Padding="18"
                                CornerRadius="8"
                                Background="White"
                                BorderBrush="#DCE1E8"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}"
                                           Foreground="#5A6472"
                                           FontSize="13" />
                                <TextBlock Text="{Binding Value}"
                                           Foreground="#18202A"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ContentControl Grid.Row="1"
                            Margin="0,22,0,0"
                            AutomationProperties.AutomationId="ChartArea">
                <Border Padding="18"
                        CornerRadius="8"
                        Background="White"
                        BorderBrush="#DCE1E8"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Activity"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#18202A" />
                        <TextBlock Grid.Column="1"
                                   Text="Apps"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#18202A" />
                        <TextBlock Grid.Column="2"
                                   Text="Domains"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#18202A" />

                        <lvc:CartesianChart Grid.Row="1"
                                            AutomationProperties.AutomationId="HourlyActivityChart"
                                            MinHeight="220"
                                            Series="{Binding HourlyActivityChart.Series}" />
                        <lvc:CartesianChart Grid.Row="1"
                                            Grid.Column="1"
                                            AutomationProperties.AutomationId="AppUsageChart"
                                            MinHeight="220"
                                            Series="{Binding AppUsageChart.Series}" />
                        <lvc:PieChart Grid.Row="1"
                                      Grid.Column="2"
                                      AutomationProperties.AutomationId="DomainUsageChart"
                                      MinHeight="220"
                                      Series="{Binding DomainUsageSeries}" />
                    </Grid>
                </Border>
            </ContentControl>

            <Border Grid.Row="2"
                    Margin="0,16,0,0"
                    Padding="18"
                    CornerRadius="8"
                    Background="White"
                    BorderBrush="#DCE1E8"
                    BorderThickness="1">
                <TabControl AutomationProperties.AutomationId="DashboardTabs">
                    <TabItem Header="App Sessions"
                             AutomationProperties.AutomationId="AppSessionsTab">
                        <DataGrid Margin="0,12,0,0"
                                  AutomationProperties.AutomationId="RecentAppSessionsList"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding RecentSessions}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="App"
                                                    Binding="{Binding AppName}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Started"
                                                    Binding="{Binding StartedAtLocal}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Duration"
                                                    Binding="{Binding Duration}"
                                                    Width="110" />
                                <DataGridCheckBoxColumn Header="Idle"
                                                        Binding="{Binding IsIdle}"
                                                        Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Web Sessions"
                             AutomationProperties.AutomationId="WebSessionsTab">
                        <DataGrid Margin="0,12,0,0"
                                  AutomationProperties.AutomationId="RecentWebSessionsList"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding RecentWebSessions}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Domain"
                                                    Binding="{Binding Domain}"
                                                    Width="180" />
                                <DataGridTextColumn Header="Page"
                                                    Binding="{Binding PageTitle}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Started"
                                                    Binding="{Binding StartedAtLocal}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Duration"
                                                    Binding="{Binding Duration}"
                                                    Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Live Event Log"
                             AutomationProperties.AutomationId="LiveEventsTab">
                        <DataGrid Margin="0,12,0,0"
                                  AutomationProperties.AutomationId="LiveEventsList"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding LiveEvents}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time"
                                                    Binding="{Binding OccurredAtLocal}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Kind"
                                                    Binding="{Binding Kind}"
                                                    Width="120" />
                                <DataGridTextColumn Header="Message"
                                                    Binding="{Binding Message}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Settings"
                             AutomationProperties.AutomationId="SettingsTab">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <CheckBox Content="Collection visible"
                                      AutomationProperties.AutomationId="CollectionVisibleCheckBox"
                                      IsChecked="{Binding Settings.IsCollectionVisible}"
                                      FontSize="14"
                                      Margin="0,0,0,12" />
                            <CheckBox Grid.Row="1"
                                      Content="Show window titles"
                                      AutomationProperties.AutomationId="WindowTitleVisibleCheckBox"
                                      IsChecked="{Binding Settings.IsWindowTitleVisible}"
                                      FontSize="14"
                                      Margin="0,0,0,12" />
                            <CheckBox Grid.Row="2"
                                      Content="Sync enabled"
                                      AutomationProperties.AutomationId="SyncEnabledCheckBox"
                                      IsChecked="{Binding Settings.IsSyncEnabled}"
                                      FontSize="14"
                                      Margin="0,0,0,12" />
                            <TextBlock Grid.Row="3"
                                       AutomationProperties.AutomationId="BrowserUrlPrivacyText"
                                       Text="Browser URL storage is domain-only by default. Full URLs require explicit future opt-in."
                                       Foreground="#5A6472"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />
                            <TextBlock Grid.Row="4"
                                       AutomationProperties.AutomationId="SyncModeLabel"
                                       Text="{Binding Settings.SyncModeLabel}"
                                       Foreground="#5A6472"
                                       FontSize="13" />
                            <TextBlock Grid.Row="5"
                                       Margin="0,8,0,0"
                                       AutomationProperties.AutomationId="SyncStatusLabel"
                                       Text="{Binding Settings.SyncStatusLabel}"
                                       Foreground="#8A4B00"
                                       FontSize="13"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
    </ScrollViewer>
</Window>

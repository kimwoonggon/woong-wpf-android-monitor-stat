<Application x:Class="Woong.MonitorStack.Windows.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml" />
                <ResourceDictionary Source="Styles/Typography.xaml" />
                <ResourceDictionary Source="Styles/Buttons.xaml" />
                <ResourceDictionary Source="Styles/Cards.xaml" />
                <ResourceDictionary Source="Styles/Badges.xaml" />
                <ResourceDictionary Source="Styles/DataGrid.xaml" />
                <ResourceDictionary Source="Styles/Inputs.xaml" />
                <ResourceDictionary Source="Styles/Tabs.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DrawingImage x:Key="WoongAppIconImage">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="{StaticResource AppIconBackgroundBrush}"
                                         Geometry="M 4 4 L 28 4 L 28 28 L 4 28 Z" />
                        <GeometryDrawing Brush="{StaticResource AppIconAccentBrush}"
                                         Geometry="M 8 20 L 12 20 L 12 24 L 8 24 Z M 14 12 L 18 12 L 18 24 L 14 24 Z M 20 8 L 24 8 L 24 24 L 20 24 Z" />
                        <GeometryDrawing Brush="{StaticResource AppIconForegroundBrush}"
                                         Geometry="M 8 8 L 16 8 L 16 10 L 8 10 Z M 8 13 L 12 13 L 12 15 L 8 15 Z" />
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
        </ResourceDictionary>
    </Application.Resources>
</Application>

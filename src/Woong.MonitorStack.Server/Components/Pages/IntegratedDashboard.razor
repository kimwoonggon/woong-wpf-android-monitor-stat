@page "/dashboard"
@using System.Globalization
@inject IntegratedDashboardQueryService DashboardQuery

<PageTitle>Integrated Device Dashboard</PageTitle>
@if (PollingRefreshSeconds is not null)
{
    <HeadContent>
        <meta http-equiv="refresh" content="@PollingRefreshSeconds" />
    </HeadContent>
}

<section class="dashboard-shell">
    <header class="hero">
        <div>
            <p class="eyebrow">Windows + Android</p>
            <h1>Integrated Device Dashboard</h1>
            <p class="subtitle">@FromDateText - @ToDateText / @ResolvedTimezoneId</p>
        </div>
        <div class="status-stack" aria-label="Dashboard source badges">
            <span class="status-pill">PostgreSQL integrated view</span>
            <span class="status-pill safe">Metadata only</span>
        </div>
    </header>

    <section class="polling-panel" aria-label="Polling interval controls">
        <div>
            <strong>Polling interval</strong>
            <span class="muted">Refresh PostgreSQL-backed dashboard data on this page.</span>
        </div>
        <nav class="polling-buttons" aria-label="Dashboard polling interval">
            <a class="@PollingButtonClass("off")" href="@BuildPollingUrl("off")" data-polling-query="polling=off">Off</a>
            <a class="@PollingButtonClass("1s")" href="@BuildPollingUrl("1s")" data-polling-query="polling=1s">1s</a>
            <a class="@PollingButtonClass("5s")" href="@BuildPollingUrl("5s")" data-polling-query="polling=5s">5s</a>
            <a class="@PollingButtonClass("10s")" href="@BuildPollingUrl("10s")" data-polling-query="polling=10s">10s</a>
            <a class="@PollingButtonClass("1h")" href="@BuildPollingUrl("1h")" data-polling-query="polling=1h">1h</a>
        </nav>
    </section>

    @if (_error is not null)
    {
        <div class="message error">@_error</div>
    }
    else if (_snapshot is null)
    {
        <div class="message">Loading dashboard...</div>
    }
    else
    {
        <section class="view-section">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Combined View</p>
                    <h2>Windows + Android active focus</h2>
                </div>
                <p class="muted">Both clients stay local-first. This page reads only synced PostgreSQL facts.</p>
            </div>

            <div class="metric-grid" aria-label="Integrated summary cards">
                <article class="metric-card primary">
                    <span>Active Focus</span>
                    <strong>@FormatDuration(_snapshot.TotalActiveMs)</strong>
                    <small>Idle excluded across Windows and Android</small>
                </article>
                <article class="metric-card">
                    <span>Idle</span>
                    <strong>@FormatDuration(_snapshot.TotalIdleMs)</strong>
                    <small>Foreground but inactive</small>
                </article>
                <article class="metric-card">
                    <span>Web Focus</span>
                    <strong>@FormatDuration(_snapshot.TotalWebMs)</strong>
                    <small>Domain metadata when available</small>
                </article>
                <article class="metric-card">
                    <span>Devices</span>
                    <strong>@_snapshot.Devices.Count</strong>
                    <small>Registered devices in this range</small>
                </article>
            </div>
        </section>

        <section class="platform-grid" aria-label="Platform usage split">
            @foreach (IntegratedPlatformUsage platform in OrderedPlatformUsage)
            {
                <article class="panel platform-panel">
                    <div class="platform-title">
                        <div>
                            <p class="eyebrow">@PlatformSourceLabel(platform.Platform)</p>
                            <h2>@PlatformTitle(platform.Platform)</h2>
                        </div>
                        <strong>@FormatDuration(platform.ActiveMs)</strong>
                    </div>
                    <p class="muted">@PlatformDescription(platform.Platform)</p>

                    <div class="mini-metric-row">
                        <span>Active @FormatDuration(platform.ActiveMs)</span>
                        <span>Idle @FormatDuration(platform.IdleMs)</span>
                        <span>Web @FormatDuration(platform.WebMs)</span>
                    </div>

                    <div class="split-columns">
                        <div>
                            <h3>Top Apps</h3>
                            @if (platform.TopApps.Count == 0)
                            {
                                <p class="muted">No app sessions synced for this platform.</p>
                            }
                            @foreach (IntegratedUsageTotal app in platform.TopApps.Take(5))
                            {
                                <div class="bar-row">
                                    <span>@app.Label</span>
                                    <div class="bar-track">
                                        <div class="bar-fill" style="width:@Percent(app.DurationMs, platform.ActiveMs)%"></div>
                                    </div>
                                    <strong>@FormatDuration(app.DurationMs)</strong>
                                </div>
                            }
                        </div>

                        <div>
                            <h3>Top Domains</h3>
                            @if (platform.TopDomains.Count == 0)
                            {
                                <p class="muted">@NoDomainText(platform.Platform)</p>
                            }
                            @foreach (IntegratedUsageTotal domain in platform.TopDomains.Take(5))
                            {
                                <div class="bar-row">
                                    <span>@domain.Label</span>
                                    <div class="bar-track">
                                        <div class="bar-fill domain" style="width:@Percent(domain.DurationMs, platform.WebMs)%"></div>
                                    </div>
                                    <strong>@FormatDuration(domain.DurationMs)</strong>
                                </div>
                            }
                        </div>
                    </div>
                </article>
            }
        </section>

        <section class="dashboard-grid">
            <article class="panel">
                <h2>Platform Totals</h2>
                @foreach (IntegratedPlatformTotal platform in _snapshot.PlatformTotals)
                {
                    <div class="bar-row">
                        <span>@platform.Platform</span>
                        <div class="bar-track">
                            <div class="bar-fill" style="width:@Percent(platform.ActiveMs, _snapshot.TotalActiveMs)%"></div>
                        </div>
                        <strong>@FormatDuration(platform.ActiveMs)</strong>
                    </div>
                }
            </article>

            <article class="panel">
                <h2>Top Apps</h2>
                @foreach (IntegratedUsageTotal app in _snapshot.TopApps.Take(5))
                {
                    <div class="bar-row">
                        <span>@app.Label</span>
                        <div class="bar-track">
                            <div class="bar-fill" style="width:@Percent(app.DurationMs, _snapshot.TotalActiveMs)%"></div>
                        </div>
                        <strong>@FormatDuration(app.DurationMs)</strong>
                    </div>
                }
            </article>

            <article class="panel">
                <h2>Top Domains</h2>
                @foreach (IntegratedUsageTotal domain in _snapshot.TopDomains.Take(5))
                {
                    <div class="bar-row">
                        <span>@domain.Label</span>
                        <div class="bar-track">
                            <div class="bar-fill domain" style="width:@Percent(domain.DurationMs, _snapshot.TotalWebMs)%"></div>
                        </div>
                        <strong>@FormatDuration(domain.DurationMs)</strong>
                    </div>
                }
            </article>

            <article class="panel">
                <h2>Location Samples</h2>
                @if (_snapshot.TopLocations.Count == 0)
                {
                    <p class="muted">No opted-in location metadata in this range.</p>
                }
                @foreach (IntegratedLocationTotal location in _snapshot.TopLocations.Take(5))
                {
                    <div class="location-row">
                        <span>@location.Label</span>
                        <strong>@location.SampleCount samples</strong>
                    </div>
                }
            </article>
        </section>

        <section class="panel route-panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Location Movement Route</p>
                    <h2>Opt-in latitude/longitude route</h2>
                </div>
                <p class="muted">Rendered locally as SVG from stored location metadata. No external map tiles are loaded.</p>
            </div>

            @if (_snapshot.LocationRoute.Count == 0)
            {
                <div class="map-empty">No opted-in route points for this range.</div>
            }
            else
            {
                <div class="route-layout">
                    <svg class="route-map" viewBox="0 0 700 280" role="img" aria-label="Location route map">
                        <rect x="0" y="0" width="700" height="280" rx="18"></rect>
                        <path d="M40 55 H660 M40 110 H660 M40 165 H660 M40 220 H660 M95 30 V250 M210 30 V250 M325 30 V250 M440 30 V250 M555 30 V250"
                              class="map-grid"></path>
                        @if (_snapshot.LocationRoute.Count > 1)
                        {
                            <polyline points="@LocationPolylinePoints" class="route-line"></polyline>
                        }
                        @foreach (IntegratedLocationRoutePoint point in _snapshot.LocationRoute)
                        {
                            <circle cx="@Invariant(MapX(point))" cy="@Invariant(MapY(point))" r="7" class="route-point"></circle>
                        }
                    </svg>

                    <div class="route-list">
                        @foreach (IntegratedLocationRoutePoint point in _snapshot.LocationRoute.Take(8))
                        {
                            <div class="route-stop">
                                <strong>@point.CapturedAtUtc.ToString("HH:mm", CultureInfo.InvariantCulture)</strong>
                                <span>@point.Latitude.ToString("F4", CultureInfo.InvariantCulture), @point.Longitude.ToString("F4", CultureInfo.InvariantCulture)</span>
                                <small>@point.CaptureMode / @FormatAccuracy(point.AccuracyMeters) / @point.PermissionState</small>
                            </div>
                        }
                    </div>
                </div>
            }
        </section>

        <section class="panel device-panel">
            <h2>Devices</h2>
            <table>
                <thead>
                    <tr>
                        <th>Platform</th>
                        <th>Device</th>
                        <th>Timezone</th>
                        <th>Active</th>
                        <th>Idle</th>
                        <th>Web</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (IntegratedDeviceSummary device in _snapshot.Devices)
                    {
                        <tr>
                            <td>@device.Platform</td>
                            <td>@device.DeviceName</td>
                            <td>@device.TimezoneId</td>
                            <td>@FormatDuration(device.ActiveMs)</td>
                            <td>@FormatDuration(device.IdleMs)</td>
                            <td>@FormatDuration(device.WebMs)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
</section>

<style>
    .dashboard-shell {
        padding: 28px;
    }

    .hero,
    .section-heading,
    .platform-title {
        align-items: center;
        display: flex;
        justify-content: space-between;
        gap: 18px;
    }

    .hero {
        margin-bottom: 22px;
    }

    .eyebrow,
    .subtitle,
    .muted {
        color: var(--muted);
    }

    .eyebrow {
        font-weight: 700;
        letter-spacing: .06em;
        margin: 0 0 4px;
        text-transform: uppercase;
    }

    h1 {
        font-size: 32px;
        margin: 0;
    }

    h2 {
        font-size: 18px;
        margin: 0;
    }

    h3 {
        font-size: 15px;
        margin: 18px 0 10px;
    }

    .subtitle {
        margin: 6px 0 0;
    }

    .status-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
    }

    .status-pill {
        background: #eaf3ff;
        border: 1px solid #bfdbfe;
        border-radius: 999px;
        color: #0758bd;
        font-weight: 700;
        padding: 10px 16px;
        white-space: nowrap;
    }

    .status-pill.safe {
        background: #ecfdf5;
        border-color: #bbf7d0;
        color: #047857;
    }

    .message,
    .metric-card,
    .panel,
    .polling-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
    }

    .message {
        padding: 18px;
    }

    .message.error {
        border-color: #fecaca;
        color: #b91c1c;
    }

    .view-section,
    .platform-grid,
    .dashboard-grid,
    .route-panel,
    .device-panel,
    .polling-panel {
        margin-top: 14px;
    }

    .polling-panel {
        align-items: center;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 16px;
    }

    .polling-panel strong,
    .polling-panel span {
        display: block;
    }

    .polling-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
    }

    .polling-button {
        border: 1px solid var(--border);
        border-radius: 999px;
        color: #334155;
        font-weight: 700;
        padding: 8px 12px;
        text-decoration: none;
    }

    .polling-button.active {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    .metric-grid {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        margin-top: 14px;
    }

    .metric-card {
        padding: 18px;
    }

    .metric-card span,
    .metric-card small {
        color: var(--muted);
        display: block;
    }

    .metric-card strong {
        display: block;
        font-size: 28px;
        margin: 8px 0 4px;
    }

    .metric-card.primary {
        border-color: #bfdbfe;
        box-shadow: inset 4px 0 0 var(--primary);
    }

    .platform-grid {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .dashboard-grid {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .panel {
        padding: 18px;
    }

    .platform-panel {
        min-height: 320px;
    }

    .platform-title strong {
        color: var(--primary);
        font-size: 24px;
        white-space: nowrap;
    }

    .mini-metric-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
    }

    .mini-metric-row span {
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 999px;
        color: #334155;
        font-size: 13px;
        font-weight: 700;
        padding: 7px 10px;
    }

    .split-columns {
        display: grid;
        gap: 18px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .bar-row {
        align-items: center;
        display: grid;
        gap: 10px;
        grid-template-columns: minmax(120px, 1fr) 2fr minmax(72px, auto);
        margin: 12px 0;
    }

    .bar-track {
        background: #e5e7eb;
        border-radius: 999px;
        height: 12px;
        overflow: hidden;
    }

    .bar-fill {
        background: var(--primary);
        border-radius: inherit;
        height: 100%;
        min-width: 3px;
    }

    .bar-fill.domain {
        background: #8b5cf6;
    }

    .location-row {
        display: flex;
        justify-content: space-between;
        margin: 12px 0;
    }

    .route-layout {
        display: grid;
        gap: 18px;
        grid-template-columns: minmax(0, 1.5fr) minmax(260px, .8fr);
        margin-top: 14px;
    }

    .route-map {
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 18px;
        height: auto;
        width: 100%;
    }

    .route-map rect {
        fill: #f8fafc;
    }

    .map-grid {
        fill: none;
        stroke: #e2e8f0;
        stroke-width: 1;
    }

    .route-line {
        fill: none;
        stroke: #0f6bde;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 4;
    }

    .route-point {
        fill: #22c55e;
        stroke: #ffffff;
        stroke-width: 3;
    }

    .map-empty {
        background: #f8fafc;
        border: 1px dashed var(--border);
        border-radius: 14px;
        color: var(--muted);
        margin-top: 14px;
        padding: 28px;
        text-align: center;
    }

    .route-list {
        display: grid;
        gap: 10px;
    }

    .route-stop {
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 10px;
        display: grid;
        gap: 3px;
        padding: 10px 12px;
    }

    .route-stop small {
        color: var(--muted);
    }

    .device-panel {
        overflow-x: auto;
    }

    table {
        border-collapse: collapse;
        min-width: 720px;
        width: 100%;
    }

    th,
    td {
        border-bottom: 1px solid var(--border);
        padding: 10px 8px;
        text-align: left;
    }

    th {
        color: var(--muted);
        font-size: 13px;
    }

    @@media (max-width: 1080px) {
        .platform-grid,
        .dashboard-grid,
        .route-layout,
        .split-columns {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 760px) {
        .hero,
        .section-heading,
        .platform-title,
        .polling-panel {
            align-items: flex-start;
            flex-direction: column;
        }

        .metric-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private const double MapWidth = 700;
    private const double MapHeight = 280;
    private const double MapPadding = 34;

    [SupplyParameterFromQuery(Name = "userId")]
    public string? UserId { get; set; }

    [SupplyParameterFromQuery(Name = "from")]
    public string? From { get; set; }

    [SupplyParameterFromQuery(Name = "to")]
    public string? To { get; set; }

    [SupplyParameterFromQuery(Name = "timezoneId")]
    public string? TimezoneId { get; set; }

    [SupplyParameterFromQuery(Name = "polling")]
    public string? Polling { get; set; }

    private IntegratedDashboardSnapshot? _snapshot;
    private string? _error;

    private string FromDateText => From ?? DateOnly.FromDateTime(DateTime.UtcNow).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    private string ToDateText => To ?? FromDateText;
    private string ResolvedTimezoneId => string.IsNullOrWhiteSpace(TimezoneId) ? "UTC" : TimezoneId;
    private string ResolvedPolling => NormalizePolling(Polling);
    private int? PollingRefreshSeconds => ResolvedPolling switch
    {
        "1s" => 1,
        "5s" => 5,
        "10s" => 10,
        "1h" => 3600,
        _ => null
    };

    private IReadOnlyList<IntegratedPlatformUsage> OrderedPlatformUsage
        => _snapshot is null
            ? Array.Empty<IntegratedPlatformUsage>()
            : _snapshot.PlatformUsage.OrderBy(PlatformSortOrder).ToList();

    private string LocationPolylinePoints
        => _snapshot is null
            ? string.Empty
            : string.Join(" ", _snapshot.LocationRoute.Select(point => $"{Invariant(MapX(point))},{Invariant(MapY(point))}"));

    protected override async Task OnParametersSetAsync()
    {
        string userId = string.IsNullOrWhiteSpace(UserId) ? "local-user" : UserId;

        if (!DateOnly.TryParse(FromDateText, out DateOnly fromDate) ||
            !DateOnly.TryParse(ToDateText, out DateOnly toDate))
        {
            _error = "Use ISO dates such as 2026-04-30 for from/to.";
            return;
        }

        _error = null;
        _snapshot = await DashboardQuery.GetAsync(userId, fromDate, toDate, ResolvedTimezoneId);
    }

    private static int Percent(long value, long total)
        => total <= 0 ? 0 : Math.Clamp((int)Math.Round(value * 100.0 / total), 0, 100);

    private static string FormatDuration(long durationMs)
    {
        TimeSpan duration = TimeSpan.FromMilliseconds(durationMs);

        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours}h {duration.Minutes:D2}m";
        }

        return $"{Math.Max(0, (int)duration.TotalMinutes)}m";
    }

    private static string FormatAccuracy(double? accuracyMeters)
        => accuracyMeters.HasValue
            ? $"+/- {accuracyMeters.Value:0}m"
            : "accuracy unknown";

    private static string PlatformTitle(string platform)
        => platform.Equals("windows", StringComparison.OrdinalIgnoreCase)
            ? "Windows View"
            : platform.Equals("android", StringComparison.OrdinalIgnoreCase)
                ? "Android View"
                : CultureInfo.InvariantCulture.TextInfo.ToTitleCase(platform);

    private static string PlatformSourceLabel(string platform)
        => platform.Equals("windows", StringComparison.OrdinalIgnoreCase)
            ? "WPF / SQLite / Sync"
            : platform.Equals("android", StringComparison.OrdinalIgnoreCase)
                ? "Android / Room / UsageStats"
                : "Device Platform";

    private static string PlatformDescription(string platform)
        => platform.Equals("windows", StringComparison.OrdinalIgnoreCase)
            ? "Windows apps and domains from foreground sessions, browser sessions, local SQLite, and uploaded DTOs."
            : platform.Equals("android", StringComparison.OrdinalIgnoreCase)
                ? "Android apps and domains from UsageStats app sessions; Chrome domain switching is only shown if explicitly synced by a supported future source."
                : "Platform-specific metadata synced through the shared API contract.";

    private static string NoDomainText(string platform)
        => platform.Equals("android", StringComparison.OrdinalIgnoreCase)
            ? "Android Chrome per-domain WebSession switching is not inferred from UsageStats."
            : "No browser-domain sessions synced for this platform.";

    private static int PlatformSortOrder(IntegratedPlatformUsage usage)
        => usage.Platform switch
        {
            "windows" => 0,
            "android" => 1,
            _ => 2
        };

    private double MapX(IntegratedLocationRoutePoint point)
    {
        if (_snapshot is null || _snapshot.LocationRoute.Count <= 1)
        {
            return MapWidth / 2;
        }

        double minLongitude = _snapshot.LocationRoute.Min(routePoint => routePoint.Longitude);
        double maxLongitude = _snapshot.LocationRoute.Max(routePoint => routePoint.Longitude);
        double range = maxLongitude - minLongitude;

        if (range <= 0)
        {
            return MapWidth / 2;
        }

        return MapPadding + ((point.Longitude - minLongitude) / range * (MapWidth - MapPadding * 2));
    }

    private double MapY(IntegratedLocationRoutePoint point)
    {
        if (_snapshot is null || _snapshot.LocationRoute.Count <= 1)
        {
            return MapHeight / 2;
        }

        double minLatitude = _snapshot.LocationRoute.Min(routePoint => routePoint.Latitude);
        double maxLatitude = _snapshot.LocationRoute.Max(routePoint => routePoint.Latitude);
        double range = maxLatitude - minLatitude;

        if (range <= 0)
        {
            return MapHeight / 2;
        }

        return MapHeight - MapPadding - ((point.Latitude - minLatitude) / range * (MapHeight - MapPadding * 2));
    }

    private static string Invariant(double value)
        => value.ToString("0.###", CultureInfo.InvariantCulture);

    private string PollingButtonClass(string polling)
        => string.Equals(ResolvedPolling, polling, StringComparison.OrdinalIgnoreCase)
            ? "polling-button active"
            : "polling-button";

    private string BuildPollingUrl(string polling)
        => string.Create(
            CultureInfo.InvariantCulture,
            $"/dashboard?userId={Escape(UserId ?? "local-user")}&from={Escape(FromDateText)}&to={Escape(ToDateText)}&timezoneId={Escape(ResolvedTimezoneId)}&polling={Escape(polling)}");

    private static string NormalizePolling(string? polling)
        => polling?.Trim().ToLowerInvariant() switch
        {
            "1s" => "1s",
            "5s" => "5s",
            "10s" => "10s",
            "1h" => "1h",
            _ => "off"
        };

    private static string Escape(string value)
        => Uri.EscapeDataString(value);
}

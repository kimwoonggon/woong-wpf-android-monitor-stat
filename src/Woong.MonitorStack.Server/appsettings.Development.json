{
  "RawEventRetention": {
    "Enabled": false,
    "RetentionDays": 30,
    "Interval": "1.00:00:00",
    "FailureAlertEnabled": false,
    "FailureAlertAfterConsecutiveFailures": 3,
    "HighDeleteCountAlertThreshold": 10000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

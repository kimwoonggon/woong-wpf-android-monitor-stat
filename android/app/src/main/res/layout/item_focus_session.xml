<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/focusSessionRowRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="72dp"
    android:paddingStart="12dp"
    android:paddingTop="6dp"
    android:paddingEnd="12dp"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/sessionAppIconPlaceholder"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_rounded_icon_placeholder"
        android:gravity="center"
        android:text="A"
        android:textColor="@color/wms_text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/sessionAppNameText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/wms_text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/sessionPackageText"
        app:layout_constraintEnd_toStartOf="@id/sessionDurationText"
        app:layout_constraintStart_toEndOf="@id/sessionAppIconPlaceholder"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/sessionPackageText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/wms_text_secondary"
        android:textSize="11sp"
        app:layout_constraintBottom_toTopOf="@id/sessionTimeRangeText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/sessionAppNameText"
        app:layout_constraintTop_toBottomOf="@id/sessionAppNameText" />

    <TextView
        android:id="@+id/sessionTimeRangeText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/wms_text_secondary"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/sessionStateText"
        app:layout_constraintStart_toStartOf="@id/sessionAppNameText"
        app:layout_constraintTop_toBottomOf="@id/sessionPackageText" />

    <TextView
        android:id="@+id/sessionStateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/wms_info"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/sessionTimeRangeText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/sessionTimeRangeText" />

    <TextView
        android:id="@+id/sessionDurationText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/wms_text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/sessionAppNameText" />
</androidx.constraintlayout.widget.ConstraintLayout>

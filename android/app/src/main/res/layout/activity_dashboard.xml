<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <TextView
        android:id="@+id/dashboardTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/dashboard_title"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/periodFilters"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dashboardTitle">

        <Button
            android:id="@+id/todayFilterButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/filter_today" />

        <Button
            android:id="@+id/yesterdayFilterButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/filter_yesterday" />

        <Button
            android:id="@+id/recent7DaysFilterButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/filter_recent_7_days" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/totalActiveCard"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginTop="20dp"
        android:background="#F4F7FB"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintEnd_toStartOf="@id/topAppCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/periodFilters">

        <TextView
            android:id="@+id/totalActiveLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/total_active"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption" />

        <TextView
            android:id="@+id/totalActiveText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/zero_duration"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/topAppCard"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="20dp"
        android:background="#F3F8F5"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/totalActiveCard"
        app:layout_constraintTop_toBottomOf="@id/periodFilters">

        <TextView
            android:id="@+id/topAppLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/top_app"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption" />

        <TextView
            android:id="@+id/topAppText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_top_app"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/idleCard"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginTop="8dp"
        android:background="#FFF8E6"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/totalActiveCard">

        <TextView
            android:id="@+id/idleLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/idle_time"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption" />

        <TextView
            android:id="@+id/idleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/zero_duration"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/usageAccessGuidanceText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/usage_access_guidance"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/idleCard" />

    <Button
        android:id="@+id/usageAccessSettingsButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:text="@string/usage_access_settings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/usageAccessGuidanceText" />

    <TextView
        android:id="@+id/recentSessionsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/recent_sessions"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/usageAccessSettingsButton" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recentSessionsList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/recentSessionsTitle" />

    <TextView
        android:id="@+id/emptySessionsText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/empty_sessions"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
        app:layout_constraintBottom_toBottomOf="@id/recentSessionsList"
        app:layout_constraintEnd_toEndOf="@id/recentSessionsList"
        app:layout_constraintStart_toStartOf="@id/recentSessionsList"
        app:layout_constraintTop_toTopOf="@id/recentSessionsList" />

</androidx.constraintlayout.widget.ConstraintLayout>

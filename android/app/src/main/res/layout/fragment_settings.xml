<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsScrollRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wms_background"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/settingsContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/settingsTitle"
            style="@style/WmsScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/permissionsSettingsCard"
            style="@style/WmsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/WmsSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Permissions" />

                <TextView
                    android:id="@+id/collectionVisibleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/collection_visible_default"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                    android:textColor="@color/wms_text_primary" />

                <TextView
                    android:id="@+id/usageAccessGuidanceText"
                    style="@style/WmsKeyValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/usage_access_guidance" />

                <TextView
                    android:id="@+id/sensitiveDataBoundaryText"
                    style="@style/WmsKeyValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sensitive_data_boundary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openUsageAccessSettingsButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="14dp"
                    android:text="@string/usage_access_settings"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/syncSettingsCard"
            style="@style/WmsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/WmsSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sync" />

                <TextView
                    android:id="@+id/syncOptInText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/sync_opt_in_default"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                    android:textColor="@color/wms_text_primary" />

                <TextView
                    android:id="@+id/syncStatusText"
                    style="@style/WmsKeyValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_local_only_status" />

                <TextView
                    android:id="@+id/notificationPermissionGuidanceText"
                    style="@style/WmsKeyValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/notification_permission_guidance" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/requestNotificationPermissionButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/request_notification_permission"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/privacySettingsCard"
            style="@style/WmsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/WmsSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Privacy boundaries" />

                <TextView
                    style="@style/WmsKeyValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sensitive_data_boundary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/locationSettingsCard"
            style="@style/WmsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/WmsSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Location context" />

                <TextView
                    android:id="@+id/locationContextDefaultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/location_context_default"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                    android:textColor="@color/wms_text_primary" />

                <TextView
                    android:id="@+id/locationCoordinateBoundaryText"
                    style="@style/WmsKeyValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/location_coordinate_boundary" />

                <TextView
                    android:id="@+id/preciseLocationOptInText"
                    style="@style/WmsKeyValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/precise_location_opt_in" />

                <CheckBox
                    android:id="@+id/locationContextCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/store_optional_location_context"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                    android:textColor="@color/wms_text_primary" />

                <CheckBox
                    android:id="@+id/preciseLatitudeLongitudeCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"
                    android:text="@string/store_precise_latitude_longitude"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                    android:textColor="@color/wms_text_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/requestLocationPermissionButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/request_location_permission"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/storageSettingsCard"
            style="@style/WmsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/WmsSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Storage" />

                <TextView
                    style="@style/WmsKeyValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Room keeps Android-only local usage data. Server sync is off until explicitly enabled." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

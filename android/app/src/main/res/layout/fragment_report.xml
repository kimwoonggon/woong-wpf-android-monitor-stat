<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reportScrollRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wms_background"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/reportContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/reportTitle"
            style="@style/WmsScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/report_title" />

        <TextView
            android:id="@+id/reportSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/report_subtitle"
            android:textColor="@color/wms_text_secondary"
            android:textSize="14sp" />

        <HorizontalScrollView
            android:id="@+id/reportPeriodScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/reportPeriodRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/reportSevenDayButton"
                    style="@style/WmsPeriodButton.Selected"
                    android:text="@string/filter_7d" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/reportThirtyDayButton"
                    style="@style/WmsPeriodButton"
                    android:text="@string/filter_30d" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/reportNinetyDayButton"
                    style="@style/WmsPeriodButton"
                    android:text="@string/filter_90d" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/reportCustomButton"
                    style="@style/WmsPeriodButton"
                    android:text="@string/filter_custom" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/reportDateRangeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/report_date_range_placeholder"
            android:textColor="@color/wms_text_secondary"
            android:textSize="13sp" />

        <GridLayout
            android:id="@+id/reportMetricGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <include
                android:id="@+id/reportTotalFocusCard"
                layout="@layout/item_summary_card" />

            <include
                android:id="@+id/reportAverageCard"
                layout="@layout/item_summary_card" />

            <include
                android:id="@+id/reportTopAppCard"
                layout="@layout/item_summary_card" />
        </GridLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/reportTrendChartCard"
            style="@style/WmsCard"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    style="@style/WmsSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/daily_usage_trend" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/sevenDayTrendChart"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/reportTopAppsCard"
            style="@style/WmsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    style="@style/WmsSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/top_apps_7_days" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/reportTopAppsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

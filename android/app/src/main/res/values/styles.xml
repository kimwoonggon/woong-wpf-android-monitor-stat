<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WoongMonitor" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary_dark</item>
        <item name="colorAccent">@color/brand_accent</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/wms_surface</item>
    </style>

    <style name="WmsCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/wms_surface</item>
        <item name="strokeColor">@color/wms_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="WmsScreenTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/wms_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WmsSectionTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/wms_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WmsKeyValueText" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/wms_text_secondary</item>
        <item name="android:layout_marginTop">6dp</item>
    </style>

    <style name="WmsStatusChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/bg_status_chip_neutral</item>
    </style>

    <style name="WmsStatusChip.Success" parent="WmsStatusChip">
        <item name="android:textColor">@color/wms_success</item>
    </style>

    <style name="WmsStatusChip.Warning" parent="WmsStatusChip">
        <item name="android:textColor">@color/wms_warning</item>
    </style>

    <style name="WmsStatusChip.Info" parent="WmsStatusChip">
        <item name="android:textColor">@color/wms_info</item>
    </style>

    <style name="WmsPeriodButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:minWidth">80dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="WmsPeriodButton.Selected" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:minWidth">80dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">10dp</item>
    </style>
</resources>
